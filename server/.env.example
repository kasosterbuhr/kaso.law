# Local audio backend for Classroom uploads.
PORT=8787
ALLOWED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,https://kaso.law,https://www.kaso.law

# Required for podcast generation.
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# Required for NotebookLM Enterprise notebook creation.
GOOGLE_CLOUD_PROJECT_NUMBER=123456789012
GOOGLE_CLOUD_LOCATION=global
NOTEBOOKLM_UI_IDENTITY_MODE=google

# Provide either GOOGLE_SERVICE_ACCOUNT_JSON / _BASE64 or the split vars below.
# GOOGLE_SERVICE_ACCOUNT_JSON={...full JSON service account...}
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=base64_encoded_service_account_json
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional cleanup window for generated MP3 files.
AUDIO_JOB_TTL_HOURS=24
